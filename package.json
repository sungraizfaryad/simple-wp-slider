{
  "name": "simple-wp-slider",
  "version": "2.0.0",
  "private": true,
  "license": "GPL-2.0-or-later",
  "scripts": {
    "start": "wp-scripts start --webpack-src-dir=src --output-path=assets/dist",
    "build": "wp-scripts build --webpack-src-dir=src --output-path=assets/dist",
    "lint:js": "wp-scripts lint-js src",
    "lint:css": "wp-scripts lint-style \"src/**/*.{css,scss}\"",
    "format": "wp-scripts format src",
    "packages-update": "wp-scripts packages-update",
    "makepot": "wp i18n make-pot . languages/simple-wp-slider.pot --slug=simple-wp-slider --domain=simple-wp-slider --exclude=node_modules,src,assets/dist,tests,docs,vendor"
  },
  "devDependencies": {
    "@wordpress/scripts": "^30.0.0",
    "@wordpress/api-fetch": "^7.0.0",
    "@wordpress/blocks": "^14.0.0",
    "@wordpress/block-editor": "^14.0.0",
    "@wordpress/components": "^28.0.0",
    "@wordpress/data": "^10.0.0",
    "@wordpress/element": "^6.0.0",
    "@wordpress/i18n": "^5.0.0",
    "@wordpress/server-side-render": "^5.0.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "dependencies": {
    "swiper": "^11.1.0"
  }
}
